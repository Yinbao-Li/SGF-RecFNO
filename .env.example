# Copy to .env and adjust paths for your machine.
# export $(grep -v '^#' .env | xargs)

# Repository root (auto-detected if unset)
# RECFNO_REPO_ROOT=/path/to/RecFNO

# Dataset directory (default: $REPO/data or ../data)
RECFNO_DATA_ROOT=/path/to/data

# External baseline repos (default: $REPO/external)
RECFNO_EXTERNAL_ROOT=/path/to/external

# Training log / checkpoint root (default: heat2D/logs when running heat experiments)
# RECFNO_LOG_ROOT=/path/to/logs
