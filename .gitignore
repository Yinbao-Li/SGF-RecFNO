# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
recfno.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.so

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Environment
.env

# Training logs (checkpoints/ at repo root is tracked separately)
**/logs/
**/nohup.out
**/tb/
**/events.out.tfevents.*

# Ignore stray checkpoints outside checkpoints/
*.pth
*.pt
*.ckpt
!checkpoints/**/*.pth

# Data — bundled split files tracked via Git LFS (see data/heat/README.md)
data/**/*.h5
!data/heat/train.h5
!data/heat/val.h5
!data/heat/test.h5
data/**/*.pickle
data/**/*.mat
!data/.gitkeep
!data/heat/splits.json
!data/heat/README.md

# External baseline repos
external/
!external/.gitkeep
